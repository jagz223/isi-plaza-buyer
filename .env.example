# URL del backend Laravel (sin barra final)
# Emulador Android: la app convierte 127.0.0.1 → 10.0.2.2 automáticamente
# Local: http://127.0.0.1:8000  |  Producción (APK): https://isi-plaza-admin.onrender.com
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Google OAuth (expo-auth-session)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Firebase (app Web en Firebase Console). Sin comillas ni comas al final.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# false = si Firestore falla o app_enabled es false → pantalla negra
EXPO_PUBLIC_PLATFORM_ACCESS_FAIL_OPEN=false
